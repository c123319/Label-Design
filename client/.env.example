# 远程模板库根 URL（不含尾部斜杠）
# 开发环境默认 /template-store（由 Vite 本地静态服务提供）
# 生产部署示例：
# VITE_TEMPLATE_STORE_BASE_URL=https://raw.githubusercontent.com/xxx/template-store/main

# 资源域名白名单（逗号分隔，留空表示不限制）
# VITE_TEMPLATE_STORE_ALLOWED_HOSTS=raw.githubusercontent.com,gitee.com

# ── 自部署后端源 ──
# 后端服务根 URL。同源部署（前后端同域）时留空即可；
# 分离部署时填写后端域名，如 https://api.example.com
# VITE_BACKEND_STORE_BASE_URL=https://api.example.com

# 是否启用私有模板库 Tab / 素材源切换。
# 设置了 VITE_BACKEND_STORE_BASE_URL 后会自动启用，无需再显式开关。
# 显式开关示例：VITE_BACKEND_STORE_ENABLED=true

